#!/bin/sh
set -eu

# Re-run when the tracked Fish plugin manifest changes:
# fish_plugins hash: {{ include "dot_config/private_fish/fish_plugins" | sha256sum }}

if ! command -v fish >/dev/null 2>&1; then
  echo "fish is not installed; cannot install Fisher plugins" >&2
  exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is not installed; cannot bootstrap Fisher" >&2
  exit 1
fi

fish -c '
if not type -q fisher
    curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
end

fisher update
'
